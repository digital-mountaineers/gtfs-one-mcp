# Copy to deploy/.env and fill in. docker compose reads this automatically.

# The public subdomain that will serve the MCP endpoint (DNS A record → this host).
MCP_DOMAIN=mcp.devbydm.com
# Email for Let's Encrypt cert notices.
ACME_EMAIL=jordan@digitalmountaineers.com

# Which GTFS Pro site this connector serves.
GTFS_PRO_URL=https://staging8.mountaintransit.org
GTFS_PRO_AGENCY_NAME=Mountain Transit
GTFS_PRO_FEED_ID=default

# Optional: require Authorization: Bearer <token> on the endpoint. Leave blank for open.
MCP_AUTH_TOKEN=
