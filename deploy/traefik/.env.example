# Copy to deploy/traefik/.env and fill in. docker compose reads it automatically.

# Subdomain Traefik routes + gets a cert for. Must have a DNS record pointing at
# the host (Cloudflare-proxied is fine when Traefik's letsencrypt uses DNS-01).
MCP_DOMAIN=mcp.devbydm.com

# Which GTFS Pro site this connector serves.
GTFS_PRO_URL=https://staging8.mountaintransit.org
GTFS_PRO_AGENCY_NAME=Mountain Transit
GTFS_PRO_FEED_ID=default

# Optional: require Authorization: Bearer <token>. Leave blank for an open server.
MCP_AUTH_TOKEN=
